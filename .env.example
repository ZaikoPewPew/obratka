# Supabase (anon / publishable — можно в клиенте)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Telegram Login Widget (публичные)
# BotFather → token: число до двоеточия = BOT_ID
TELEGRAM_BOT_ID=
TELEGRAM_BOT_USERNAME=

# TELEGRAM_BOT_TOKEN — только в Supabase Edge Function secrets, не сюда

# Google OAuth — без клиентских env: Client ID/Secret только в
# Supabase Dashboard → Authentication → Providers → Google.
# Email OTP — там же → Providers → Email (включить OTP; шаблон Magic Link: {{ .Token }}).
# Automatic linking Email↔Google — из коробки; Manual linking не включать без UI.
# Redirect URLs: http://localhost:5173/ и https://zaikopewpew.github.io/obratka/
# (см. src/components/auth-screen/README.md)
