# Supabase (anon / publishable — можно в клиенте)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Telegram Login Widget (публичные)
# BotFather → token: число до двоеточия = BOT_ID
TELEGRAM_BOT_ID=
TELEGRAM_BOT_USERNAME=

# TELEGRAM_BOT_TOKEN — только в Supabase Edge Function secrets, не сюда
